# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key for LLM and embeddings generation (required)
GEMINI_API_KEY=

# GitHub personal access token, for higher API rate limits (optional)
GITHUB_TOKEN=

# Local directory where ChromaDB collections are stored
CHROMA_DB_DIR=./chroma_db

# Gemini embedding batching (optional overrides, see src/core/config.py for defaults)
GEMINI_EMBEDDING_BATCH_SIZE=4
GEMINI_EMBEDDING_MAX_BATCH_CHARS=8000
GEMINI_EMBEDDING_BATCH_DELAY_SECONDS=2.0

# Request-level rate limiting, per client IP (optional overrides)
INGEST_RATE_LIMIT_PER_MINUTE=5
QUERY_RATE_LIMIT_PER_MINUTE=20
