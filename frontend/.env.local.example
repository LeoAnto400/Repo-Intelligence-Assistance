# Copy this file to .env.local and fill in values as needed.

# Left unset intentionally: api-client.ts resolves the backend host dynamically
# from the page's own hostname (so this works from localhost and from other
# devices on the LAN). Set this explicitly (including the /api/v1 prefix) only
# if the backend runs on a different host/port than the frontend.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
